# Copy to .env. Docker compose reads .env automatically.

# Path to the Stockfish binary inside the container. The Debian package
# installs it at /usr/games/stockfish.
ENGINE_PATH=/usr/games/stockfish

# Where the SQLite database lives (inside the container)
DATABASE_URL=sqlite:////data/chess.db

# Starting Elo for a brand-new player. Stockfish's UCI_Elo floor is 1320,
# so anything below that uses the Skill Level fallback.
START_ELO=1000

# Player display name on the index page
PLAYER_NAME=you

# Seconds Stockfish thinks per move. Higher = stronger and slower analysis.
ENGINE_THINK_SECONDS=0.3
